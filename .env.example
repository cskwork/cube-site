# =============================================================================
# Target site — default URL rendered inside the cube's live face. Users can
# override this at runtime in the 공유 tab; the value below is just the
# first-load default.
# =============================================================================

TARGET_URL=https://example.com

# Optional cosmetic defaults for the styled "card" fallback mode (used when
# the target site blocks iframes via X-Frame-Options / CSP).
TARGET_NAME=Live Site
TARGET_TITLE=내 사이트,\n바로 입장
TARGET_SUB=원하는 어떤 URL이든 큐브 안에 띄울 수 있어요.
TARGET_CHIPS=3D · HTML in Canvas · Vite
TARGET_CTA_LABEL=입장
TARGET_TAGLINE=3D 사이트 큐브

# =============================================================================
# Chrome HTML-in-Canvas Origin Trial (optional)
# =============================================================================
# This project uses an interactive CSS3D iframe by default, so the OT is
# NOT required for runtime behavior. The token is still injected into a
# <meta http-equiv="origin-trial"> tag in case future iterations bring back
# the canvas-snapshot path.
# Get a token at https://developer.chrome.com/origintrials/ — feature
# "HTML element in Canvas2D".
OT_TOKEN=

# =============================================================================
# Deploy
# =============================================================================
# Base path for sub-path deploys (e.g. GitHub Pages project pages → /repo-name/)
BASE_PATH=/
